{
    "functions":{
        "api/**/*.php":{
            "runtime": "vercel-php@0.7.2"
        }
    },
    "rewrites":[
        {"source": "/login", "destination": "/api/login.php" },
        {"source": "/signup", "destination": "/api/signup.php" },

        {"source": "/api/proses/:file.php", "destination": "/api/proses/:file.php"},
        { "source": "/proses/(.*)", "destination": "/api/proses/$1"},
        {"source": "/api/:file.php", "destination": "/api/:file.php"},

        {"source": "/css/(.*)", "destination": "/css/$1" },
        {"source": "/js/(.*)", "destination": "/js/$1" },
        {"source": "/img/(.*)", "destination": "/img/$1" },
        {"source": "/(.*)", "destination": "/index.html"}
      
    ]
}